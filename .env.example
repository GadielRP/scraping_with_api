# =========================================================
# Docker / Compose
# =========================================================

APP_ENV_FILE=.env
REQUIREMENTS_FILE=requirements_cloud.txt


# =========================================================
# PostgreSQL / Database
# =========================================================

POSTGRES_DB=sofascore_odds
POSTGRES_USER=sofascore
POSTGRES_PASSWORD=change_me

# IMPORTANT:
# Inside Docker Compose, the database host is "postgres", not "localhost" or "127.0.0.1".
DATABASE_URL=postgresql+psycopg://sofascore:change_me@postgres:5432/sofascore_odds

DB_CONNECT_TIMEOUT=5


# =========================================================
# Redis
# Optional. Not used by default.
# =========================================================

REDIS_URL=


# =========================================================
# Scheduler Configuration
# =========================================================

POLL_INTERVAL_MINUTES=5
DISCOVERY_INTERVAL_HOURS=3
DISCOVERY2_INTERVAL_HOURS=6
PRE_START_WINDOW_MINUTES=120
PRE_START_WORKERS=5

INTRADAY_RESULT_FRESHNESS_WINDOW_MINUTES=390


# =========================================================
# Timezone
# =========================================================

TIMEZONE=America/Mexico_City
TZ=America/Mexico_City


# =========================================================
# Debug / Pipeline Toggles
# =========================================================

global_debug_mode=true
ENABLE_PILLAR_PIPELINE=true
ENABLE_LEGACY_ALERT_PIPELINE=false
ENABLE_STANDINGS_COMPETITION_METADATA_ENRICHMENT=true
FORCE_STANDINGS_COMPETITION_METADATA_REFRESH=false


# =========================================================
# Matchup / Standings Settings
# =========================================================

MATCHUP_STANDINGS_GROUP_BY_CONFERENCE=false


# =========================================================
# Logging
# =========================================================

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s


# =========================================================
# Rate Limiting / Retries
# =========================================================

REQUEST_DELAY_SECONDS=0.5
MAX_RETRIES=3

# OddsPapi API (ODDSPAPI_KEY is the official variable name)
ODDSPAPI_KEY=
ODDSPAPI_BASE_URL=https://api.oddspapi.io
ODDSPAPI_TIMEOUT_SECONDS=15
ODDSPAPI_DEFAULT_BOOKMAKERS=pinnacle
ODDSPAPI_DEFAULT_LANGUAGE=en
ODDSPAPI_DEFAULT_ODDS_FORMAT=decimal
ODDSPAPI_DEFAULT_VERBOSITY=3


# =========================================================
# Notifications - Telegram
# =========================================================

NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TEST_ONLY_MODE=true
PERSONAL_CHAT_ID=
EXTRA_CHAT_IDS=


# =========================================================
# Proxy Configuration
# =========================================================

PROXY_ENABLED=true
PROXY_PROVIDER=decodo
PROXY_PROTOCOL=http

PROXY_COUNTRY=mx
PROXY_CITY=
PROXY_SESSION_DURATION_MINUTES=5

PROXY_MODE_ODDSPORTAL=sticky
PROXY_MODE_SOFASCORE=rotating

PROXY_USERNAME=
PROXY_USERNAME_BASE=
PROXY_PASSWORD=
PROXY_ENDPOINT=

PROXY_ROTATION_INTERVAL=5
PROXY_MAX_RETRIES=3

PROXY_ROTATE_ON_ODDSPORTAL_BROWSER_RESTART=true
PROXY_ROTATE_ON_SOFASCORE_PROXY_ERROR=true
PROXY_LOG_SAFE=true


# =========================================================
# OddsPortal General
# =========================================================

ODDSPORTAL_SCRAPING_ENABLED=false
ODDSPORTAL_UI_LANGUAGE=en

ODDSPORTAL_PARALLEL_BROWSERS=1
ODDSPORTAL_PREVIOUS_CYCLE_TIMEOUT=120
ODDSPORTAL_ALERT_WAIT_TIMEOUT=180

ODDSPORTAL_BLOCK_RESOURCES=true
ODDSPORTAL_BLOCK_SERVICE_WORKERS=true
ODDSPORTAL_PRE_NAVIGATION_CLEAR_STATE=true


# =========================================================
# OddsPortal Timeouts / Diagnostics
# =========================================================

ODDSPORTAL_MATCH_GOTO_TIMEOUT_MS=30000
ODDSPORTAL_FAST_FAIL_EMPTY_TIMEOUT_MS=15000
ODDSPORTAL_MARKET_RENDER_TIMEOUT_MS=60000
ODDSPORTAL_SHELL_GRACE_TIMEOUT_MS=8000
ODDSPORTAL_TAB_WAIT_TIMEOUT=20

ODDSPORTAL_SAVE_DEBUG_ON_GOTO_TIMEOUT=true
ODDSPORTAL_ENABLE_SHELL_GRACE=true
ODDSPORTAL_IGNORE_HTTPS_ERRORS=true
ODDSPORTAL_FRESH_CONTEXT_PER_EVENT=true


# =========================================================
# Odds / Extraction Toggles
# =========================================================

ENABLE_TIMESTAMP_CORRECTION=false
ENABLE_ODDS_EXTRACTION=true
TRACKED_SEASONS_TOGGLE=false
FILTER_ALERTS_BY_OP_SEASON=true

STREAK_ALERT_MIN_RESULTS=15


# =========================================================
# Discovery / Filters
# =========================================================

# CSV format is safer for Docker env files.
# The app parser can handle comma-separated values.
EXCLUDED_SPORTS=Table tennis,Darts

# Empty means no explicit source filter.
DISCOVERY_SOURCES_FOR_ALERTS=


# =========================================================
# Dual Process Variables
# These are only for the dual-process / latest 1X2, Home/Away view.
# =========================================================

MARKETS_DUAL_PROCESS=1X2,Home/Away
PERIODS_DUAL_PROCESS=Full Time

# Optional filters for pre-start odds trajectory.
# Leave empty or unset to include all markets and all periods.
PRE_START_ODDS_TRAJECTORY_MARKETS=
PRE_START_ODDS_TRAJECTORY_PERIODS=


# =========================================================
# External APIs
# =========================================================

# Keep this empty in the example.
ODDSpapi_KEY=
